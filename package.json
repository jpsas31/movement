{
  "name": "movement",
  "private": true,
  "scripts": {
    "dev": "concurrently \"vite\" \"uv run uvicorn main:app --host 0.0.0.0 --port 8080 --reload\"",
    "build": "vite build",
    "build:mandelverse": "node scripts/build-mandelverse-butterchurn.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "butterchurn": "^2.6.7",
    "butterchurn-presets": "2.4.7",
    "p5": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "jsdom": "^24.0.0",
    "vitest": "^1.0.0",
    "@types/p5": "^1.7.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "milkdrop-preset-converter": "^0.1.2",
    "prettier": "^3.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
